# ============================================================
#  MiniTeaTree — пример переменных окружения
#  Скопируйте в .env и заполните реальными значениями.
#  НИКОГДА не коммитьте .env с реальными секретами.
# ============================================================

# ---------- Режим ----------
APP_ENV=development            # development | production
DEBUG=false
LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR

# ---------- Приложение ----------
APP_HOST=0.0.0.0
APP_PORT=8000
# Базовый публичный URL приложения (для вебхуков, ссылок и т.д.)
PUBLIC_BASE_URL=https://example.com
# Источник, с которого разрешены CORS-запросы (URL Mini App).
# Можно несколько через запятую.
CORS_ORIGINS=https://example.com

# ---------- База данных ----------
POSTGRES_USER=miniteatree
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=miniteatree
POSTGRES_HOST=db
POSTGRES_PORT=5432
# Полная строка подключения (asyncpg). В docker-compose можно оставить как есть.
DATABASE_URL=postgresql+asyncpg://miniteatree:change_me_strong_password@db:5432/miniteatree

# ---------- Telegram Bot ----------
# Получить у @BotFather
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
# Список Telegram ID администраторов (через запятую) — могут заходить в админку/CRM.
ADMIN_TELEGRAM_IDS=123456789

# ---------- Авторизация Mini App ----------
# Секрет для подписи JWT (сгенерируйте длинную случайную строку)
JWT_SECRET=change_me_to_a_long_random_string_at_least_32_chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30
# Сколько секунд считать initData «свежим» (защита от replay-атак)
TELEGRAM_INITDATA_MAX_AGE_SECONDS=86400

# ---------- Безопасность ----------
# Загружать файлы не более этого размера (байт). По умолчанию 5 МБ.
MAX_UPLOAD_BYTES=5242880

# ---------- Админка (SQLAdmin) ----------
# Первоначальные учётные данные админа (создаются при первом запуске/миграции)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_strong_password

# ---------- T Bank Acquiring ----------
# Личный кабинет T Bank → Прием платежей → Настройки терминала
TBANK_TERMINAL_KEY=
TBANK_SECRET_KEY=
